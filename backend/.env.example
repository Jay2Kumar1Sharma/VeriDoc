# Application metadata
APP_NAME="VeriDoc RAG Assistant"
APP_VERSION="0.1.0"
ENV="local"
LOG_LEVEL="INFO"

# LLM provider keys. Anthropic is the primary provider; OpenAI is optional.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
TAVILY_API_KEY=""

# LLM configuration. Set GENERATION_MODEL/GRADING_MODEL to gemini-3.1-flash-lite
# if that model ID is enabled for your Gemini API key.
LLM_PROVIDER="gemini"
GENERATION_MODEL="gemini-2.5-flash-lite"
GRADING_MODEL="gemini-2.5-flash-lite"

# Embeddings. Defaults to local sentence-transformers for zero-key onboarding.
EMBEDDING_PROVIDER="sentence-transformers"
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"

# Local persistence
CHROMA_PERSIST_DIR="./chroma_data"
SQLITE_PATH="./app.db"

# Retrieval and graph tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
MAX_RETRIES=2
ENABLE_HALLUCINATION_CHECK=true
ENABLE_WEB_SEARCH_FALLBACK=false

# JSON array of allowed frontend origins
CORS_ORIGINS='["http://localhost:3000"]'
